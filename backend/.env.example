# App environment
ENV=development
PORT=8000

# Database (dev default: local SQLite file)
# For production on Postgres, set:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./data/app.db

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=1440

# Comma-separated emails that may use /platform-admin/ and /api/platform/* (cross-family).
# PLATFORM_ADMIN_EMAILS=tracy.zeidler@gmail.com,holt.zeidler@gmail.com

# Optional: absolute URL of the deployed web UI (no trailing slash), used in family invite emails.
# If unset, invite links use the browser Origin when the owner sends the invite from the app.
# APP_PUBLIC_BASE_URL=https://yourname.github.io/your-repo

# Optional: one-click contact form (SMTP). Set all to enable POST /api/public/contact.
# Microsoft 365: create an app password for the mailbox (Security → app passwords) and
# ensure "SMTP AUTH" is allowed for that user in Microsoft 365 / Exchange admin.
# CONTACT_SMTP_HOST=smtp.office365.com
# CONTACT_SMTP_PORT=587
# CONTACT_SMTP_USER=support@balancewhiz.com
# CONTACT_SMTP_PASSWORD=your-app-password
# CONTACT_EMAIL_TO=support@balancewhiz.com
# CONTACT_EMAIL_FROM=
# Optional tuning (defaults are fine). Overall deadline caps HTTP wait so the contact page does not hang.
# CONTACT_SMTP_SOCKET_TIMEOUT_SEC=18
# CONTACT_SMTP_OVERALL_DEADLINE_SEC=26
# If SMTP always times out from your host, many PaaS block outbound port 587; use a mail API (e.g. Resend) instead.

# Optional: Resend (https://resend.com) — recommended on Render when SMTP to Microsoft 365 times out.
# Free tier: create API key, verify domain balancewhiz.com (or use onboarding@resend.dev only to your signup email for tests).
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=BalanceWhiz <newsletter@balancewhiz.com>
# CONTACT_EMAIL_TO=support@balancewhiz.com

